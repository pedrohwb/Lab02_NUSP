# --------------------------------------------------------------------------
# Configuração do PostgreSQL
# --------------------------------------------------------------------------

POSTGRES_DB=lab02_retail
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Para execução LOCAL (sem Docker):
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# Para execução em CONTAINER (docker compose):
# O host deve ser o nome do serviço no docker-compose.yml ("postgres")
# e a porta interna do container (5432).
# Ao usar "docker compose run ingestion ...", sobrescreva assim:
#   POSTGRES_HOST=postgres
#   POSTGRES_PORT=5432
